{"date": "2026-06-06", "owner": "NousResearch", "name": "hermes-agent", "url": "https://github.com/NousResearch/hermes-agent", "description": "The agent that grows with you", "primary_language": "Python", "topics": ["ai", "ai-agent", "ai-agents", "anthropic", "chatgpt", "claude", "claude-code", "clawdbot", "codex", "hermes", "hermes-agent", "llm", "moltbot", "nous-research", "openai", "openclaw"], "stars": 183977, "forks": 31527, "contributors_count": 1454, "created_at": "2025-07-22T22:22:28Z", "pushed_at": "2026-06-06T08:22:53Z", "license": "MIT", "readme_excerpt": "**The self-improving AI agent built by Nous Research.** It's the only agent with a built-in learning loop \u2014 it creates skills from experience, improves them during use, nudges itself to persist knowledge, searches its own past conversations, and builds a deepening model of who you are across sessions. Run it on a $5 VPS, a GPU cluster, or serverless infrastructure that costs nearly nothing when idle. It's not tied to your laptop \u2014 talk to it from Telegram while it works on a cloud VM.", "sources": ["trending:daily"], "hn_url": null, "hn_points": null, "hn_comments": null, "reddit_url": null, "reddit_score": null}
